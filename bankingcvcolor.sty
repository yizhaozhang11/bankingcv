%-------------------------------------------------------------------------------
%                identification
%-------------------------------------------------------------------------------
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{bankingcvcolor}[2026-02-22 v1.2.0 modern curriculum vitae and letter color schemes]


%-------------------------------------------------------------------------------
%                requirements
%-------------------------------------------------------------------------------
\RequirePackage{bankingcvcolors}


%-------------------------------------------------------------------------------
%                color schemes
%-------------------------------------------------------------------------------
\newcommand*{\bankingcv@scheme@black}{%
  \colorlet{color0}{black}%
  \colorlet{color1}{black}%
  \colorlet{color2}{black}%
  \colorlet{headTL}{lightblack}%
  \colorlet{headBR}{color1}%
  \colorlet{headtext}{white}%
  \colorlet{headhr}{color2}}

\newcommand*{\bankingcv@scheme@blue}{%
  \colorlet{color0}{black}%
  \colorlet{color1}{lightblue}%
  \colorlet{color2}{darkgrey}%
