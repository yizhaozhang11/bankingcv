\newcommand*{\bankingcv@scheme@red}{%
  \colorlet{color0}{black}%
  \colorlet{color1}{red}%
  \colorlet{color2}{darkgrey}%
  \colorlet{headTL}{firebrick}%
  \colorlet{headBR}{color1}%
  \colorlet{headtext}{white}%
  \colorlet{headhr}{color2}}

\newcommand*{\bankingcvsetcolor}[1]{%
  \@ifundefined{bankingcv@scheme@#1}{%
    \PackageError{bankingcvcolor}{Unknown color scheme '#1'}%
      {Use one of: black, blue, burgundy, cerulean, green, grey, orange, purple, red.}%
  }{%
    \csname bankingcv@scheme@#1\endcsname}}


%-------------------------------------------------------------------------------
%                options
%-------------------------------------------------------------------------------
\DeclareOption{black}    {\bankingcvsetcolor{black}}
\DeclareOption{blue}     {\bankingcvsetcolor{blue}}
\DeclareOption{burgundy} {\bankingcvsetcolor{burgundy}}
\DeclareOption{cerulean} {\bankingcvsetcolor{cerulean}}
\DeclareOption{green}    {\bankingcvsetcolor{green}}
\DeclareOption{grey}     {\bankingcvsetcolor{grey}}
\DeclareOption{orange}   {\bankingcvsetcolor{orange}}
\DeclareOption{purple}   {\bankingcvsetcolor{purple}}
\DeclareOption{red}      {\bankingcvsetcolor{red}}
\DeclareOption*          {\bankingcvsetcolor{\CurrentOption}}
\ExecuteOptions{blue}
\ProcessOptions\relax

\endinput


