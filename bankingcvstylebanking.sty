%-------------------------------------------------------------------------------
%                identification
%-------------------------------------------------------------------------------
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{bankingcvstylebanking}[2026-02-20 v1.0.0 banking-style curriculum vitae style]

% body rules type options: "fullrules", "shortrules", "mixedrules" (default) or "norules"
\@initializecommand{\bankingcvbodyoptions}{}
\DeclareOption{fullrules}    {\edef\bankingcvbodyoptions{\bankingcvbodyoptions,fullrules}}
\DeclareOption{shortrules}   {\edef\bankingcvbodyoptions{\bankingcvbodyoptions,shortrules}}
\DeclareOption{mixedrules}   {\edef\bankingcvbodyoptions{\bankingcvbodyoptions,mixedrules}}
\DeclareOption{norules}      {\edef\bankingcvbodyoptions{\bankingcvbodyoptions,norules}}

% body section alignment options: "left" (default), "center" or "right"
\DeclareOption{left}         {\edef\bankingcvbodyoptions{\bankingcvbodyoptions,left}}
\DeclareOption{center}       {\edef\bankingcvbodyoptions{\bankingcvbodyoptions,center}}
\DeclareOption{right}        {\edef\bankingcvbodyoptions{\bankingcvbodyoptions,right}}

% head options
\@initializecommand{\bankingcvheadoptions}{}
\@initializeif{\if@datainhead}\@datainheadtrue
\DeclareOption{details}{\edef\bankingcvheadoptions{\bankingcvheadoptions,details}}
\DeclareOption{nodetails}{\@datainheadfalse\edef\bankingcvheadoptions{\bankingcvheadoptions,nodetails}}

% toggle use of symbol fonts.
\@initializeif{\if@symbols}\@symbolsfalse
\DeclareOption{symbols}      {\@symbolstrue}
\DeclareOption{nosymbols}    {\@symbolsfalse}

\DeclareOption*{}% avoid choking on unknown options
\ExecuteOptions{mixedrules,left,symbols}
\ProcessOptions*\relax% \ProcessOptions* processes the options in the order provided (i.e., with the later ones possibly overriding the former ones), while \ProcessOptions processes them in the order of the package


%-------------------------------------------------------------------------------
%                fonts & icons
%-------------------------------------------------------------------------------
% TeX Gyre Pagella font
%\ifxetexorluatex
%  \setmainfont{Tex-Gyre Pagella}
%  \setsansfont{Tex-Gyre Pagella}
%  \setmathfont{Tex-Gyre Pagella}
%  \setmathfont[range=\mathit,\mathsfit]{Tex-Gyre Pagella Italic}
%  \setmathfont[range=\mathbfup,\mathbfsfup]{Tex-Gyre Pagella Bold}
%  \setmathfont[range=\mathbfit,\mathbfsfit]{Tex-Gyre Pagella Bold Italic}
%\else
  \IfFileExists{tgpagella.sty}%
    {%
      \RequirePackage{tgpagella}%
      \renewcommand*{\familydefault}{\rmdefault}}%
    {}
